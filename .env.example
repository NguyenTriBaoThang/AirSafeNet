# =========================
# AirSafeNet Environment Example
# =========================

# ASP.NET Core backend URL
ASPNETCORE_URLS=http://localhost:5000

# Frontend public API base URL
VITE_API_BASE_URL=http://localhost:5000

# AI server host / port
AI_SERVER_HOST=127.0.0.1
AI_SERVER_PORT=8000
AI_SERVER_BASE_URL=http://127.0.0.1:8000

# Active model path for AI server
AI_MODEL_PATH=./ai/models/model.pkl
AI_MODEL_VERSION=airsafenet-pm25-rf-v1.0

# Environment
APP_ENV=Development
LOG_LEVEL=Information

# Optional future settings
ENABLE_SWAGGER=true
ENABLE_CORS_ALL=true
ENABLE_FORECAST_CACHE=false
FORECAST_CACHE_MINUTES=15

# Optional external data endpoints
OPEN_METEO_AIR_QUALITY_URL=https://air-quality-api.open-meteo.com/v1/air-quality
OPEN_METEO_WEATHER_URL=https://api.open-meteo.com/v1/forecast
